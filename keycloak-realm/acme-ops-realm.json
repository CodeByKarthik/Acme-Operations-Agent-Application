{
  "realm": "acme",
  "enabled": true,
  "displayName": "Acme Operations",
  "roles": {
    "realm": [
      {
        "name": "sales_user",
        "description": "Read-only access to customer and issue data"
      },
      {
        "name": "support_user",
        "description": "Read and update access for support issues"
      },
      {
        "name": "admin",
        "description": "Full administrative access"
      }
    ]
  },
  "clients": [
    {
      "clientId": "acme-agent-api",
      "name": "Acme Agent API",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-only-client-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://localhost:8000/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:8000",
        "http://localhost:3000"
      ],
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "email"
      ],
      "protocolMappers": [
        {
          "name": "user-id",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-subject-mapper",
          "consentRequired": false,
          "config": {
            "access.token.claim": "true",
            "claim.name": "sub",
            "id.token.claim": "true",
            "jsonType.label": "String",
            "userinfo.token.claim": "true"
          }
        }
      ]
    }
  ],
  "users": [
    {
      "username": "sales1",
      "enabled": true,
      "email": "sales1@acme.local",
      "firstName": "Sales",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "SalesPass123",
          "temporary": false
        }
      ],
      "realmRoles": ["sales_user"]
    },
    {
      "username": "support1",
      "enabled": true,
      "email": "support1@acme.local",
      "firstName": "Support",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "SupportPass123",
          "temporary": false
        }
      ],
      "realmRoles": ["support_user"]
    },
    {
      "username": "admin1",
      "enabled": true,
      "email": "admin1@acme.local",
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "AdminPass123",
          "temporary": false
        }
      ],
      "realmRoles": ["admin"]
    }
  ]
}